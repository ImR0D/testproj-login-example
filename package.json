    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/localize": "^21.2.17",
    "jsdom": "^28.0.0",
    "ng-extract-i18n-merge": "^3.4.0",
